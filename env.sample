# LLM API Configuration
# Comma-separated list of API keys for round-robin rotation
LLM_API_KEYS=sk-your-first-api-key,sk-your-second-api-key,sk-your-third-api-key

# API Base URL (e.g., https://api.openai.com/v1 or your custom endpoint)
LLM_API_BASE_URL=https://api.openai.com/v1

# Model name to use
LLM_MODEL=gpt-4o-mini

# Number of retries for failed API calls
LLM_MAX_RETRIES=3

# Timeout in milliseconds for API calls
LLM_TIMEOUT=60000

# Batch size for PDF processing (number of pages per API call)
PDF_BATCH_SIZE=5
